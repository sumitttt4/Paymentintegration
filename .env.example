# ──────────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────

# The connection string for your PostgreSQL database.
# For production/staging, neonatal database is recommended: neon.tech
# Example format: postgresql://[user]:[password]@[host]/[dbname]?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"


# ──────────────────────────────────────────────────────────────────────────────
# BETTER AUTH CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────

# Secret key used to sign Better Auth tokens and cookies.
# Generate a secure 32+ character random string (e.g., run `openssl rand -hex 32`)
BETTER_AUTH_SECRET="your_better_auth_secret_here"

# The base URL of your application.
# - For local development: http://localhost:3000
# - For production: https://yourdomain.com
BETTER_AUTH_URL="http://localhost:3000"


# ──────────────────────────────────────────────────────────────────────────────
# DODO PAYMENTS KEYS
# ──────────────────────────────────────────────────────────────────────────────

# API key for Dodo Payments.
# Get this from Dodo Dashboard > Developer > API Keys (starts with "live_sk_" or "test_sk_")
DODO_PAYMENTS_API_KEY="test_sk_your_dodo_api_key_here"

# Webhook secret to verify incoming webhooks from Dodo.
# Expose your server via ngrok (e.g. `ngrok http 3000`) and configure the webhook URL:
# https://[your-ngrok-or-domain]/api/auth/dodopayments/webhooks
# Copy the secret from Dodo Dashboard > Developer > Webhooks
DODO_PAYMENTS_WEBHOOK_SECRET="whsec_your_dodo_webhook_secret_here"

# API environment mode. Set to 'test_mode' for sandbox and 'live_mode' for production.
DODO_PAYMENTS_ENVIRONMENT="test_mode"


# ──────────────────────────────────────────────────────────────────────────────
# DODO PRODUCT IDS (Keep in sync with your Dodo Payments Dashboard)
# ──────────────────────────────────────────────────────────────────────────────

# The product ID for the "Pro" subscription plan.
# Create this product in Dodo Dashboard > Products and copy the ID (starts with "pdt_")
NEXT_PUBLIC_DODO_PRO_PRODUCT_ID="pdt_your_pro_product_id_here"

# The product ID for the "Enterprise" subscription plan.
# Create this product in Dodo Dashboard > Products and copy the ID (starts with "pdt_")
NEXT_PUBLIC_DODO_ENTERPRISE_PRODUCT_ID="pdt_your_enterprise_product_id_here"
